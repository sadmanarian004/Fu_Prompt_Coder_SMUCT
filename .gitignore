# ---------------------------------------------------------------------------
# Environment files — NEVER commit these. This is the #1 priority in this file
# after the .env wipe/mismatch issues today.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.local.example

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/

# ---------------------------------------------------------------------------
# Next.js (frontend)
# ---------------------------------------------------------------------------
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts
frontend/.turbo/

# ---------------------------------------------------------------------------
# Backend build output
# ---------------------------------------------------------------------------
backend/dist/
backend/build/

# ---------------------------------------------------------------------------
# Prisma
# ---------------------------------------------------------------------------
# Keep schema.prisma and migrations/ tracked — only ignore generated client
# output if it's ever emitted outside node_modules, and local dev DB files.
backend/prisma/*.db
backend/prisma/dev.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---------------------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# TypeScript build info
# ---------------------------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.local
.cache/